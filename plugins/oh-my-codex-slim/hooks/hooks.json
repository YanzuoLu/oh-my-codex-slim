        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/components/orchestrator-hook/cli.cjs\" hook session-start",
            "timeout": 7
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
